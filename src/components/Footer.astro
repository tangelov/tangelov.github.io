---
import { NAVIGATION, SOCIAL_LINKS, SITE } from '@config/site';
---

<!-- Footer Widgets Section -->
<div class="bg-[#252525] py-16">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-4">
      <!-- Company Info -->
      <div class="lg:col-span-1 space-y-6">
        <a href="/" class="flex items-center space-x-3 group">
          <img 
            src="/favicon-192.png" 
            alt="Вита Бургас" 
            class="h-12 w-auto"
          />
          <span class="text-2xl font-bold text-white font-['Raleway']">
            Вита
          </span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Физиотерапевтичен център "Вита" - вашият партньор за здраве и възстановяване от 2001 г.
        </p>
        <div class="flex space-x-3">
          <a
            href={SOCIAL_LINKS.facebook}
            class="w-9 h-9 flex items-center justify-center rounded-full bg-[#2e2e2e] text-gray-400 hover:text-white hover:bg-[#3b5998] transition-all"
            aria-label="Facebook"
            target="_blank"
            rel="noopener"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/>
            </svg>
          </a>
          <a
            href={SOCIAL_LINKS.instagram}
            class="w-9 h-9 flex items-center justify-center rounded-full bg-[#2e2e2e] text-gray-400 hover:text-white hover:bg-gradient-to-r hover:from-purple-500 hover:to-pink-500 transition-all"
            aria-label="Instagram"
            target="_blank"
            rel="noopener"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href={SOCIAL_LINKS.youtube}
            class="w-9 h-9 flex items-center justify-center rounded-full bg-[#2e2e2e] text-gray-400 hover:text-white hover:bg-[#c4302b] transition-all"
            aria-label="YouTube"
            target="_blank"
            rel="noopener"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-[#c5c5c5] mb-6 font-['Raleway']">
          Навигация
        </h3>
        <ul class="space-y-3">
          {NAVIGATION.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-gray-400 hover:text-[#d65050] transition-colors"
              >
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-[#c5c5c5] mb-6 font-['Raleway']">
          Процедури
        </h3>
        <ul class="space-y-3">
          <li>
            <a href="/procedures" class="text-sm text-gray-400 hover:text-[#d65050] transition-colors">
              Физиотерапия
            </a>
          </li>
          <li>
            <a href="/procedures" class="text-sm text-gray-400 hover:text-[#d65050] transition-colors">
              Лазертерапия
            </a>
          </li>
          <li>
            <a href="/procedures" class="text-sm text-gray-400 hover:text-[#d65050] transition-colors">
              Кинезитерапия
            </a>
          </li>
          <li>
            <a href="/procedures" class="text-sm text-gray-400 hover:text-[#d65050] transition-colors">
              Масаж
            </a>
          </li>
          <li>
            <a href="/procedures" class="text-sm text-gray-400 hover:text-[#d65050] transition-colors">
              Естетични процедури
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-[#c5c5c5] mb-6 font-['Raleway']">
          Контакти
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start space-x-3">
            <span class="text-[#d65050] mt-0.5">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </span>
            <span class="text-sm text-gray-400 leading-relaxed">{SITE.address}</span>
          </li>
          <li class="flex items-center space-x-3">
            <span class="text-[#d65050]">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
              </svg>
            </span>
            <a href={`tel:${SITE.phone}`} class="text-sm text-gray-400 hover:text-[#d65050] transition-colors">{SITE.phone}</a>
          </li>
          <li class="flex items-center space-x-3">
            <span class="text-[#d65050]">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
            </span>
            <a href={`mailto:${SITE.email}`} class="text-sm text-gray-400 hover:text-[#d65050] transition-colors">{SITE.email}</a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>
  
<!-- Footer Bottom -->
<footer class="bg-[#1c1c1c] py-4">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm text-[#666666]">
      © {new Date().getFullYear()} Физиотерапевтичен Център "Вита" - Бургас. Всички права запазени.
    </p>
  </div>
</footer>
