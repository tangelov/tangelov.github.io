---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config/site';
import { getCollection, getEntry, render } from 'astro:content';

// Get page content
const aboutPage = await getEntry('pages', 'about');
let AboutContent = null;
if (aboutPage) {
  const rendered = await render(aboutPage);
  AboutContent = rendered.Content;
}

const teamMembers = await getCollection('team');
const sortedTeam = teamMembers.sort((a, b) => a.data.order - b.data.order);

// Render each team member's content
const teamWithContent = await Promise.all(
  sortedTeam.map(async (member) => {
    const { Content: MemberContent } = await render(member);
    return { ...member, MemberContent };
  })
);

const pageTitle = aboutPage?.data?.title || 'За нас';
const pageDescription = aboutPage?.data?.description || "Научете повече за екипа на Физиотерапевтичен Център 'Вита' в Бургас";
---

<BaseLayout 
  title={`${pageTitle} | ${SITE.title}`} 
  description={pageDescription}
  keywords="физиотерапевтичен център Вита, екип специалисти, физикална медицина Бургас, рехабилитация специалисти"
>
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center bg-cover bg-center" style="background-image: url('/images/backgrounds/burgas-bridge.jpg');">
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl py-20">
        <span class="inline-block px-4 py-2 text-sm font-medium text-white bg-[#d65050] rounded-full mb-6">
          За нас
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold mb-6 text-white font-heading">
          Нашата мисия
        </h1>
        <p class="text-xl text-white/90">
          От 2001 година се грижим за здравето и благополучието на нашите пациенти в Бургас.
        </p>
      </div>
    </div>
  </section>

  <!-- About Content -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="prose prose-lg prose-slate max-w-none">
          {AboutContent ? <AboutContent /> : (
            <>
              <h2>Физиотерапевтичен Център "Вита"</h2>
              <p>Физиотерапевтичен Център "Вита" е основан през 2001 година с мисията да предоставя висококачествени медицински услуги в областта на физикалната терапия и рехабилитация.</p>
            </>
          )}
        </div>
        <div class="relative">
          <div class="bg-[#f5f5f5] rounded-3xl p-8">
            <div class="grid grid-cols-2 gap-6">
              <div class="bg-white rounded-2xl p-6 shadow-lg text-center">
                <div class="text-4xl font-bold text-[#d65050] mb-2">25+</div>
                <div class="text-sm text-[#47425d]">години опит</div>
              </div>
              <div class="bg-white rounded-2xl p-6 shadow-lg text-center">
                <div class="text-4xl font-bold text-[#d65050] mb-2">1000+</div>
                <div class="text-sm text-[#47425d]">доволни пациенти</div>
              </div>
              <div class="bg-white rounded-2xl p-6 shadow-lg text-center">
                <div class="text-4xl font-bold text-[#d65050] mb-2">6+</div>
                <div class="text-sm text-[#47425d]">вида терапии</div>
              </div>
              <div class="bg-white rounded-2xl p-6 shadow-lg text-center">
                <div class="text-4xl font-bold text-[#d65050] mb-2">4</div>
                <div class="text-sm text-[#47425d]">специалисти</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-20 bg-[#f5f5f5]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-[#d65050] uppercase tracking-wider">Нашият екип</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-[#443f3f] font-heading">
          Запознайте се с нашите специалисти
        </h2>
        <div class="w-16 h-1 bg-[#d65050] mx-auto mt-4"></div>
        <p class="mt-4 text-lg text-[#47425d] max-w-2xl mx-auto">
          Екип от опитни професионалисти, посветени на вашето здраве и възстановяване.
        </p>
      </div>
      
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {teamWithContent.map((member) => (
          <div class="bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow text-center group">
            {member.data.image ? (
              <div class="w-24 h-24 mx-auto mb-6 rounded-full overflow-hidden group-hover:scale-110 transition-transform">
                <img src={member.data.image} alt={member.data.name} class="w-full h-full object-cover" />
              </div>
            ) : (
              <div class="w-24 h-24 mx-auto mb-6 flex items-center justify-center text-5xl bg-[#f5f5f5] rounded-full group-hover:scale-110 transition-transform">
                {member.data.icon || '👤'}
              </div>
            )}
            <h3 class="text-xl font-bold text-[#443f3f] mb-2">{member.data.name}</h3>
            <p class="text-sm font-medium text-[#d65050] mb-4">{member.data.role}</p>
            <div class="text-sm text-[#47425d] prose prose-sm">
              <member.MemberContent />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
