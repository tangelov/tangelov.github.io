---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE, SOCIAL_LINKS } from '@config/site';
---

<BaseLayout 
  title={`Контакти | ${SITE.title}`} 
  description="Свържете се с Физиотерапевтичен Център 'Вита' в Бургас. Адрес, телефон и работно време."
  keywords="Вита Бургас контакти, физиотерапевтичен център адрес, физиотерапия Бургас телефон"
>
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center bg-cover bg-center" style="background-image: url('/images/backgrounds/burgas-bridge.jpg');">
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl py-20">
        <span class="inline-block px-4 py-2 text-sm font-medium text-white bg-[#d65050] rounded-full mb-6">
          Свържете се с нас
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold mb-6 text-white font-heading">
          Контакти
        </h1>
        <p class="text-xl text-white/90">
          Ще се радваме да отговорим на вашите въпроси и да ви помогнем.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-[#443f3f] mb-8 font-heading">Информация за контакт</h2>
          
          <div class="space-y-6">
            <!-- Address -->
            <div class="flex items-start p-6 bg-[#f5f5f5] rounded-2xl">
              <div class="w-12 h-12 flex items-center justify-center bg-[#d65050]/10 text-[#d65050] rounded-xl mr-4 flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f] mb-1">Адрес</h3>
                <p class="text-[#47425d]">{SITE.address}</p>
                <p class="text-[#47425d]">гр. Бургас</p>
              </div>
            </div>

            <!-- Phone -->
            <div class="flex items-start p-6 bg-[#f5f5f5] rounded-2xl">
              <div class="w-12 h-12 flex items-center justify-center bg-[#d65050]/10 text-[#d65050] rounded-xl mr-4 flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f] mb-1">Телефон</h3>
                <a href={`tel:${SITE.phone}`} class="text-[#d65050] hover:text-[#c04545] font-medium text-lg">
                  {SITE.phone}
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start p-6 bg-[#f5f5f5] rounded-2xl">
              <div class="w-12 h-12 flex items-center justify-center bg-[#d65050]/10 text-[#d65050] rounded-xl mr-4 flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f] mb-1">Имейл</h3>
                <a href={`mailto:${SITE.email}`} class="text-[#d65050] hover:text-[#c04545] font-medium">
                  {SITE.email}
                </a>
              </div>
            </div>

            <!-- Working Hours -->
            <div class="flex items-start p-6 bg-[#f5f5f5] rounded-2xl">
              <div class="w-12 h-12 flex items-center justify-center bg-[#d65050]/10 text-[#d65050] rounded-xl mr-4 flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f] mb-1">Работно време</h3>
                <p class="text-[#47425d]">Понеделник - Петък: 09:00 - 18:00</p>
                <p class="text-[#47425d]">Събота и Неделя: Почивни дни</p>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div class="mt-10">
            <h3 class="font-semibold text-[#443f3f] mb-4">Следвайте ни</h3>
            <div class="flex space-x-4">
              <a
                href={SOCIAL_LINKS.facebook}
                class="w-12 h-12 flex items-center justify-center bg-[#f5f5f5] text-[#47425d] hover:bg-[#d65050] hover:text-white rounded-xl transition-all"
                target="_blank"
                rel="noopener"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/>
                </svg>
              </a>
              <a
                href={SOCIAL_LINKS.instagram}
                class="w-12 h-12 flex items-center justify-center bg-[#f5f5f5] text-[#47425d] hover:bg-[#d65050] hover:text-white rounded-xl transition-all"
                target="_blank"
                rel="noopener"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
              <a
                href={SOCIAL_LINKS.youtube}
                class="w-12 h-12 flex items-center justify-center bg-[#f5f5f5] text-[#47425d] hover:bg-[#d65050] hover:text-white rounded-xl transition-all"
                target="_blank"
                rel="noopener"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Map or Contact Form Placeholder -->
        <div>
          <h2 class="text-2xl font-bold text-[#443f3f] mb-8 font-heading">Намерете ни</h2>
          <div class="bg-[#f5f5f5] rounded-3xl h-96 flex items-center justify-center">
            <div class="text-center p-8">
              <div class="w-20 h-20 mx-auto mb-6 flex items-center justify-center bg-[#d65050]/10 text-[#d65050] rounded-full">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-[#443f3f] mb-2">Физиотерапевтичен Център "Вита"</h3>
              <p class="text-[#47425d] mb-6">{SITE.address}, гр. Бургас</p>
              <a
                href="https://maps.google.com/?q=жк+Лазур+ул.+Батак+46+Бургас"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center px-6 py-3 text-sm font-medium text-white bg-[#d65050] hover:bg-[#c04545] rounded-xl transition-colors"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Отвори в Google Maps
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
