---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config/site';
import { getCollection, render } from 'astro:content';

const diseases = await getCollection('diseases');
const sortedDiseases = diseases.sort((a, b) => a.data.order - b.data.order);

// Render each disease's content
const diseasesWithContent = await Promise.all(
  sortedDiseases.map(async (disease) => {
    const { Content } = await render(disease);
    return { ...disease, Content };
  })
);
---

<BaseLayout 
  title={`Заболявания | ${SITE.title}`} 
  description="Информация за заболяванията, които лекуваме във Физиотерапевтичен Център 'Вита' - дискова болест, остеоартроза, парализа на лицев нерв."
  keywords="дискова болест лечение, остеоартроза терапия, парализа на лицев нерв, болки в гърба, болки в кръста, рехабилитация Бургас"
>
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center bg-cover bg-center" style="background-image: url('/images/backgrounds/burgas-bridge.jpg');">
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl py-20">
        <span class="inline-block px-4 py-2 text-sm font-medium text-white bg-[#d65050] rounded-full mb-6">
          Медицинска информация
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold mb-6 text-white font-heading">
          Заболявания
        </h1>
        <p class="text-xl text-white/90">
          Научете повече за заболяванията, които успешно лекуваме в нашия център.
        </p>
      </div>
    </div>
  </section>

  <!-- Diseases List -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        {diseasesWithContent.map((disease, index) => (
          <div class="bg-[#f5f5f5] rounded-3xl overflow-hidden">
            <div class="grid lg:grid-cols-3 gap-0">
              {disease.data.image && (
                <div class="lg:col-span-1 h-64 lg:h-auto">
                  <img 
                    src={disease.data.image} 
                    alt={disease.data.title} 
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class={`${disease.data.image ? 'lg:col-span-2' : 'lg:col-span-3'} p-8 md:p-10`}>
                <div class="grid lg:grid-cols-2 gap-8">
                  <div>
                    <div class="inline-flex items-center px-3 py-1 text-sm font-medium text-white bg-[#d65050] rounded-full mb-4">
                      #{index + 1}
                    </div>
                    <h2 class="text-2xl md:text-3xl font-bold text-[#443f3f] mb-4 font-heading">{disease.data.title}</h2>
                    <div class="text-[#47425d] text-lg leading-relaxed prose prose-lg">
                      <disease.Content />
                    </div>
                  </div>
                  <div class="space-y-6">
                    <div>
                      <h3 class="text-sm font-semibold text-[#443f3f] uppercase tracking-wider mb-3">Симптоми</h3>
                      <div class="flex flex-wrap gap-2">
                        {disease.data.symptoms.map((symptom) => (
                          <span class="inline-flex items-center px-3 py-1.5 text-sm text-red-700 bg-red-50 border border-red-100 rounded-lg">
                            <svg class="w-4 h-4 mr-1.5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                            </svg>
                            {symptom}
                          </span>
                        ))}
                      </div>
                    </div>
                    <div>
                      <h3 class="text-sm font-semibold text-[#443f3f] uppercase tracking-wider mb-3">Лечение</h3>
                      <div class="flex flex-wrap gap-2">
                        {disease.data.treatments.map((treatment) => (
                          <span class="inline-flex items-center px-3 py-1.5 text-sm text-[#d65050] bg-[#d65050]/10 border border-[#d65050]/20 rounded-lg">
                            <svg class="w-4 h-4 mr-1.5 text-[#d65050]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                            {treatment}
                          </span>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="py-12 bg-[#f5f5f5]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-start p-6 bg-amber-50 border border-amber-200 rounded-2xl">
        <svg class="w-6 h-6 text-amber-600 mr-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <h3 class="font-semibold text-amber-800 mb-1">Важна информация</h3>
          <p class="text-amber-700 text-sm">
            Информацията на тази страница е с образователна цел и не замества консултацията с лекар. 
            За точна диагноза и лечение, моля свържете се с нашите специалисти.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
