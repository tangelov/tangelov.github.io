---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config/site';
import { getCollection, render } from 'astro:content';

const newsEntries = await getCollection('news');
// Sort by date, newest first
const sortedNews = newsEntries.sort((a, b) => {
  const dateA = new Date(a.data.date.split('/').reverse().join('-'));
  const dateB = new Date(b.data.date.split('/').reverse().join('-'));
  return dateB.getTime() - dateA.getTime();
});
---

<BaseLayout title={`Ново | ${SITE.title}`} description="Новини и статии от Физиотерапевтичен Център 'Вита' - Бургас">
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center bg-cover bg-center" style="background-image: url('/images/backgrounds/burgas-bridge.jpg');">
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center py-20">
        <span class="inline-flex items-center px-4 py-2 rounded-full bg-[#d65050] text-white text-sm font-medium mb-6">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
          Блог и статии
        </span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 font-heading">
          Ново
        </h1>
        <p class="text-xl text-white/90 leading-relaxed">
          Полезни статии и новини от нашия екип за здраве, физиотерапия и медицина
        </p>
      </div>
    </div>
  </section>

  <!-- News Grid -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="grid gap-8">
          {sortedNews.map(async (entry) => {
            const { Content } = await render(entry);
            return (
              <article class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-lg transition-shadow">
                <div class="p-8">
                  <div class="flex items-center gap-4 mb-4">
                    <span class="inline-flex items-center px-3 py-1 rounded-full bg-[#d65050]/10 text-[#d65050] text-sm font-medium">
                      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                      </svg>
                      {entry.data.date}
                    </span>
                    {entry.data.author && (
                      <span class="text-[#47425d] text-sm">
                        от {entry.data.author}
                      </span>
                    )}
                  </div>
                  
                  <h2 class="text-2xl font-bold text-[#443f3f] mb-4 hover:text-[#d65050] transition-colors font-heading">
                    {entry.data.title}
                  </h2>
                  
                  {entry.data.excerpt && (
                    <p class="text-[#47425d] mb-4 leading-relaxed">
                      {entry.data.excerpt}
                    </p>
                  )}
                  
                  <div class="prose prose-slate prose-sm max-w-none text-[#47425d]">
                    <Content />
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- Subscribe CTA -->
  <section class="py-16 bg-[#f5f5f5]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-[#443f3f] mb-4 font-heading">
          Останете информирани
        </h2>
        <div class="w-16 h-1 bg-[#d65050] mx-auto mb-4"></div>
        <p class="text-lg text-[#47425d] mb-8">
          Следете ни в социалните мрежи за най-новите статии и съвети за здравето
        </p>
        <div class="flex justify-center gap-4">
          <a href="https://www.facebook.com/BurgasVita/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-12 h-12 bg-[#d65050] text-white rounded-full hover:bg-[#c04545] transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/vitaburgas/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-12 h-12 bg-[#d65050] text-white rounded-full hover:bg-[#c04545] transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/channel/UCsf5iSgzA-NOax42y7OF4mg" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-12 h-12 bg-[#d65050] text-white rounded-full hover:bg-[#c04545] transition-colors">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
