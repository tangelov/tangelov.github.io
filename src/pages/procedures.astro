---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config/site';
import { getCollection } from 'astro:content';

const procedures = await getCollection('procedures');
const sortedProcedures = procedures.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout 
  title={`Процедури | ${SITE.title}`} 
  description="Вижте процедурите, които предлагаме във Физиотерапевтичен Център 'Вита' - физиотерапия, кинезитерапия, масаж, лазертерапия и естетични процедури."
  keywords="физиотерапия процедури, кинезитерапия Бургас, масаж Бургас, лазертерапия, неврална терапия, естетична медицина, рехабилитация"
>
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center bg-cover bg-center" style="background-image: url('/images/backgrounds/burgas-bridge.jpg');">
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl py-20">
        <span class="inline-block px-4 py-2 text-sm font-medium text-white bg-[#d65050] rounded-full mb-6">
          Нашите услуги
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold mb-6 text-white font-heading">
          Процедури
        </h1>
        <p class="text-xl text-white/90">
          Физиотерапевтичен център ВИТА предлага много методи за физикално лечение като приоритет на дейността са именно безлекарствените физикални методи, които повлияват болката и подобряват качеството на живот.
        </p>
      </div>
    </div>
  </section>

  <!-- Procedures by Category -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
      {sortedProcedures.map((category) => (
        <div>
          <!-- Category Header -->
          <div class="flex items-center gap-4 mb-10 pb-4 border-b-2 border-[#d65050]/20">
            {category.data.image && (
              <div class="hidden md:block w-24 h-16 rounded-xl overflow-hidden flex-shrink-0">
                <img src={category.data.image} alt={category.data.title} class="w-full h-full object-cover" />
              </div>
            )}
            <div>
              <div class="flex items-center gap-3">
                <span class="text-3xl">{category.data.icon}</span>
                <h2 class="text-2xl md:text-3xl font-bold text-[#443f3f] font-heading">{category.data.title}</h2>
              </div>
            </div>
          </div>
          <!-- Individual Procedure Cards -->
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {category.data.items.map((item, i) => {
              const cardId = `${category.id}-${i}`;
              return (
                <div class="bg-white rounded-2xl border border-slate-200 hover:border-[#d65050]/40 hover:shadow-lg transition-all duration-300 p-6 flex flex-col">
                  <h3 class="text-lg font-bold text-[#443f3f] mb-2">{item.name}</h3>
                  {item.description && (
                    <p class="text-sm text-[#47425d] leading-relaxed mb-4">{item.description}</p>
                  )}
                  {item.details && (
                    <>
                      <div id={`d-${cardId}`} class="hidden mt-1 mb-4">
                        <div class="text-sm text-[#47425d] whitespace-pre-line border-t border-slate-100 pt-3">
                          {item.details}
                        </div>
                      </div>
                      <button
                        onclick="toggleDetail(this)"
                        data-target={`d-${cardId}`}
                        class="mt-auto flex items-center gap-1 text-sm font-medium text-[#d65050] hover:text-[#b83e3e] transition-colors"
                      >
                        <span data-label>Виж повече</span>
                        <svg data-arrow class="w-4 h-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </button>
                    </>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-[#f5f5f5]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[#d65050] rounded-3xl p-8 md:p-12 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 font-heading">
          Нуждаете се от консултация?
        </h2>
        <p class="text-white/90 mb-8 max-w-xl mx-auto">
          Нашите специалисти ще ви помогнат да изберете най-подходящата терапия за вашите нужди.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-[#d65050] bg-white hover:bg-gray-100 rounded-xl shadow-lg transition-all"
        >
          Свържете се с нас
        </a>
      </div>
    </div>
  </section>
<script is:inline>
  function toggleDetail(btn) {
    const id = btn.getAttribute('data-target');
    const content = document.getElementById(id);
    const label = btn.querySelector('[data-label]');
    const arrow = btn.querySelector('[data-arrow]');
    const isHidden = content.classList.toggle('hidden');
    label.textContent = isHidden ? 'Виж повече' : 'Виж по-малко';
    arrow.style.transform = isHidden ? '' : 'rotate(180deg)';
  }
</script>
</BaseLayout>
