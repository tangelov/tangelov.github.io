---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config/site';
---

<BaseLayout title={`Телемедицина | ${SITE.title}`} description="Онлайн консултации с д-р Александър Ангелов - ревматолог и специалист по мускулно-скелетна медицина">
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center bg-cover bg-center" style="background-image: url('/images/backgrounds/burgas-bridge.jpg');">
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl mx-auto text-center py-20">
        <span class="inline-flex items-center px-4 py-2 rounded-full bg-[#d65050] text-white text-sm font-medium mb-6">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          Онлайн консултации
        </span>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 font-heading">
          Телемедицина
        </h1>
        <p class="text-xl text-white/90 leading-relaxed">
          Дистанционни медицински консултации с д-р Александър Ангелов - ревматолог и специалист по мускулно-скелетна медицина
        </p>
      </div>
    </div>
  </section>

  <!-- Doctor Info Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <div class="bg-[#f5f5f5] rounded-2xl p-8 md:p-12">
          <div class="grid md:grid-cols-3 gap-8">
            <!-- Doctor Image Placeholder -->
            <div class="flex justify-center md:justify-start">
              <div class="w-48 h-48 rounded-full bg-[#d65050] flex items-center justify-center shadow-xl">
                <svg class="w-24 h-24 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            </div>
            
            <!-- Doctor Info -->
            <div class="md:col-span-2">
              <h2 class="text-2xl md:text-3xl font-bold text-[#443f3f] mb-4 font-heading">
                Д-р Александър Ангелов, дм
              </h2>
              <p class="text-lg text-[#d65050] mb-6">
                Специалист по ревматология | Докторант по медицина
              </p>
              <div class="prose prose-slate max-w-none">
                <p class="text-[#47425d] leading-relaxed mb-4">
                  Д-р Александър Ангелов е специалист по ревматология и докторант по медицина. Той предлага онлайн консултации за пациенти с проблеми със ставите, болки в гърба и кръста, както и автоимунни заболявания като ревматоиден артрит, лупус и васкулити.
                </p>
                <p class="text-[#47425d] leading-relaxed">
                  Консултациите могат да бъдат както текстови, така и видео-базирани, в зависимост от предпочитанията на пациента и сложността на случая.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Specializations Section -->
  <section class="py-16 bg-[#f5f5f5]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-[#443f3f] mb-4 font-heading">
          Области на специализация
        </h2>
        <div class="w-16 h-1 bg-[#d65050] mx-auto mb-12"></div>
        
        <div class="grid md:grid-cols-3 gap-6">
          <!-- Specialty 1 -->
          <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-lg bg-[#d65050]/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#d65050]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[#443f3f] mb-2">Ставни проблеми</h3>
            <p class="text-[#47425d] text-sm">Диагностика и лечение на заболявания на ставите, включително артрити и остеоартрози.</p>
          </div>
          
          <!-- Specialty 2 -->
          <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-lg bg-[#d65050]/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#d65050]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[#443f3f] mb-2">Болки в гърба и кръста</h3>
            <p class="text-[#47425d] text-sm">Лечение на гръбначни проблеми, дискови заболявания и хронични болкови синдроми.</p>
          </div>
          
          <!-- Specialty 3 -->
          <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-lg bg-[#d65050]/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-[#d65050]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-[#443f3f] mb-2">Автоимунни заболявания</h3>
            <p class="text-[#47425d] text-sm">Специализирана помощ при ревматоиден артрит, лупус, васкулити и други автоимунни състояния.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Qualifications Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-[#443f3f] mb-4 font-heading">
          Квалификации и опит
        </h2>
        <div class="w-16 h-1 bg-[#d65050] mx-auto mb-12"></div>
        
        <div class="grid md:grid-cols-2 gap-8">
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#d65050]/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-[#d65050]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f]">EULAR сертификат</h3>
                <p class="text-[#47425d]">Европейска сертификация по ревматология</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#d65050]/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-[#d65050]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f]">Мускулно-скелетен ултразвук</h3>
                <p class="text-[#47425d]">Опит в ултразвукова диагностика на ставите</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#d65050]/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-[#d65050]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f]">КТ и МРТ интерпретация</h3>
                <p class="text-[#47425d]">Опит в анализиране на образна диагностика</p>
              </div>
            </div>
          </div>
          
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#d65050]/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-[#d65050]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f]">Докторант по медицина</h3>
                <p class="text-[#47425d]">Активна научноизследователска дейност</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-[#d65050]/10 flex items-center justify-center flex-shrink-0 mt-1">
                <svg class="w-4 h-4 text-[#d65050]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-[#443f3f]">Рецензент в Rheumatology International</h3>
                <p class="text-[#47425d]">Рецензент в международно медицинско списание</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platforms Section -->
  <section class="py-16 bg-[#f5f5f5]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-center text-[#443f3f] mb-4 font-heading">
          Платформи за онлайн консултации
        </h2>
        <div class="w-16 h-1 bg-[#d65050] mx-auto mb-4"></div>
        <p class="text-center text-[#47425d] mb-12 max-w-2xl mx-auto">
          Изберете удобна за вас платформа за дистанционна консултация с д-р Ангелов
        </p>
        
        <div class="grid md:grid-cols-3 gap-6">
          <!-- Healee MD -->
          <a href="https://healee.com/" target="_blank" rel="noopener noreferrer" class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="text-center">
              <div class="w-16 h-16 mx-auto rounded-xl bg-[#d65050] flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="text-white font-bold text-xl">H</span>
              </div>
              <h3 class="text-lg font-semibold text-[#443f3f] mb-2">Healee MD</h3>
              <p class="text-[#47425d] text-sm">Платформа за видео консултации</p>
            </div>
          </a>
          
          <!-- Healthyco -->
          <a href="https://healthyco.bg/" target="_blank" rel="noopener noreferrer" class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="text-center">
              <div class="w-16 h-16 mx-auto rounded-xl bg-[#d65050] flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="text-white font-bold text-xl">H</span>
              </div>
              <h3 class="text-lg font-semibold text-[#443f3f] mb-2">Healthyco</h3>
              <p class="text-[#47425d] text-sm">Здравна платформа за консултации</p>
            </div>
          </a>
          
          <!-- Rod.Run -->
          <a href="https://rod.run/" target="_blank" rel="noopener noreferrer" class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1">
            <div class="text-center">
              <div class="w-16 h-16 mx-auto rounded-xl bg-[#d65050] flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <span class="text-white font-bold text-xl">R</span>
              </div>
              <h3 class="text-lg font-semibold text-[#443f3f] mb-2">Rod.Run</h3>
              <p class="text-[#47425d] text-sm">Онлайн медицински консултации</p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-[#443f3f] mb-6 font-heading">
          Имате въпроси?
        </h2>
        <p class="text-lg text-[#47425d] mb-8">
          Свържете се с нас за повече информация относно телемедицинските консултации или за записване на час.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`tel:${SITE.phone}`} class="inline-flex items-center justify-center px-6 py-3 bg-[#d65050] text-white font-medium rounded-lg hover:bg-[#c04545] transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {SITE.phone}
          </a>
          <a href="/contact" class="inline-flex items-center justify-center px-6 py-3 border-2 border-[#d65050] text-[#d65050] font-medium rounded-lg hover:bg-[#d65050]/5 transition-colors">
            Контакти
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
